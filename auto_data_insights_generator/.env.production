# ─── Production Environment Variables ───
# Copy this to .env and fill in the real values before deploying

# Django
SECRET_KEY=generate-a-strong-random-key-here
DEBUG=False
ALLOWED_HOSTS=.onrender.com,your-custom-domain.com

# Database (Render provides this automatically via render.yaml)
DATABASE_URL=postgres://user:password@host:5432/datainsights

# CORS — Your Vercel frontend URL
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://datainsights-backend.onrender.com,https://your-frontend.vercel.app

# Static files CDN — Your Vercel frontend URL (optional)
# If set, Django will serve CSS/JS from Vercel instead of WhiteNoise
#STATIC_URL_CDN=https://your-frontend.vercel.app

# AI Configuration
# Leave OLLAMA_URL empty in production if Ollama is not available
OLLAMA_URL=
OLLAMA_MODEL=tinyllama

# Optional: Gemini API (cloud AI alternative)
#GEMINI_API_KEY=your-gemini-api-key
